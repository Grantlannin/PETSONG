# Supabase (Settings -> API in your Supabase dashboard)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic (console.anthropic.com)
ANTHROPIC_API_KEY=

# MiniMax (platform.minimax.io -> Access -> Create new API key)
MINIMAX_API_KEY=
# Use music-2.6-free while testing, flip to music-2.6 for production quality
MINIMAX_MODEL=music-2.6-free

# Dashboard access
ADMIN_PASSWORD=change-me

# Base URL of the deployed app (used for magic links). http://localhost:3000 in dev.
NEXT_PUBLIC_APP_URL=http://localhost:3000
