# Supabase (Settings -> API in your Supabase dashboard)
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# Anthropic (console.anthropic.com)
ANTHROPIC_API_KEY=

# MiniMax — TWO key types (not interchangeable):
#   Pay-as-you-go: platform.minimax.io → API Keys → Create new secret key → music-2.6-free
#   Token Plan:    platform.minimax.io → Billing → Token Plan → Subscription Key → music-2.6
MINIMAX_API_KEY=
MINIMAX_MODEL=music-2.6-free
# Only if your key is from platform.minimaxi.com (China): https://api.minimaxi.com
# MINIMAX_API_HOST=https://api.minimax.io

# Dashboard access
ADMIN_PASSWORD=change-me

# Base URL of the deployed app (used for magic links). http://localhost:3000 in dev.
NEXT_PUBLIC_APP_URL=http://localhost:3000
